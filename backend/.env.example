# Copy to .env and fill in. Loaded automatically by godotenv on startup.

APP_ENV=dev
APP_PORT=8080

# PostgreSQL connection string. REQUIRED — app exits if missing.
#
# Local Docker (from docker-compose.yml):
#   postgres://panpacific:panpacific@localhost:5432/panpacific?sslmode=disable
#
# Supabase (use session-mode pooler, port 5432, with sslmode=require):
#   postgres://postgres.PROJECT_REF:PASSWORD@aws-N-REGION.pooler.supabase.com:5432/postgres?sslmode=require
#
# Do NOT use port 6543 (transaction-mode pooler) — breaks pgx prepared statements.
DATABASE_URL=postgres://panpacific:panpacific@localhost:5432/panpacific?sslmode=disable

# debug | info | warn | error
LOG_LEVEL=info

# Comma-separated allowed origins for CORS.
#   local dev:   http://localhost:5173
#   production:  https://your-app.vercel.app,http://localhost:5173
CORS_ORIGINS=http://localhost:5173
